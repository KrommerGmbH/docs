{
  "name": "@krommergmbh/cmh-chatbot",
  "version": "0.2.0",
  "description": "Lightweight AI chatbot engine powered by llama.cpp server — no Ollama, no cloud API needed",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "bin": {
    "cmh-chatbot": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs'); const p='scripts/fix-meteor-sourcemaps.cjs'; if(fs.existsSync(p)){require('child_process').execSync('node '+p,{stdio:'inherit'})} else {console.log('skip postinstall: '+p+' not found')}\"",
    "build": "tsup",
    "build:renderer": "vite build",
    "dev": "tsup --watch",
    "dev:renderer": "vite dev",
    "dev:renderer:wait": "wait-on http-get://127.0.0.1:4000/api/health && vite dev",
    "dev:llm": ".\\bin\\llama-b8712\\llama-server.exe --models-dir models --port 8080 --host 127.0.0.1 -ngl 0 -c 131072 -np 1 --mmap --models-max 1",
    "dev:engine": "pnpm build && node ./dist/cli.js start --server-url http://127.0.0.1:8080 --port 4000 --host 127.0.0.1 --no-mdns",
    "dev:cleanup": "node scripts/dev-cleanup.cjs",
    "dev:chat": "pnpm dev:cleanup && concurrently -n llm,engine,ui -c magenta,green,cyan \"pnpm dev:llm\" \"pnpm dev:engine\" \"pnpm dev:renderer:wait\"",
    "dev:all": "pnpm dev:cleanup && concurrently -n llm,engine,ui -c magenta,green,cyan \"pnpm dev:llm\" \"pnpm dev:engine\" \"pnpm dev:renderer:wait\"",
    "download:onnx": "node scripts/download-onnx-models.mjs",
    "preview:renderer": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:list": "playwright test --config playwright.config.ts --list",
    "verify:f-items": "node scripts/verify-refactor-f-items.mjs",
    "docs:dev": "vitepress dev docs --host 0.0.0.0 --port 4173",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --host 0.0.0.0 --port 4174",
    "lint": "eslint src/",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/vue": "^3.0.158",
    "@hono/node-server": "^1.13.0",
    "@huggingface/transformers": "^4.0.1",
    "@iconify-json/ph": "^1.2.2",
    "@iconify/vue": "^5.0.0",
    "@langchain/core": "^1.1.39",
    "@langchain/langgraph": "^1.2.8",
    "@langchain/openai": "^1.4.4",
    "@shopware-ag/meteor-admin-sdk": "^6.7.1",
    "@shopware-ag/meteor-component-library": "^4.28.1",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "ai": "^6.0.158",
    "bonjour-service": "^1.3.0",
    "bullmq": "^5.0.0",
    "commander": "^12.0.0",
    "edge-tts-universal": "^1.4.0",
    "hono": "^4.0.0",
    "iconify-icon": "^3.0.2",
    "ioredis": "^5.0.0",
    "keytar": "^7.9.0",
    "langchain": "^1.3.1",
    "node-cron": "^4.2.1",
    "opossum": "^8.0.0",
    "pinia": "^3.0.4",
    "pino": "^9.0.0",
    "prom-client": "^15.0.0",
    "sql.js": "^1.14.1",
    "vue": "^3.5.32",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.4",
    "ws": "^8.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@intlify/core-base": "^9.14.5",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "@types/opossum": "^8.1.9",
    "@types/ws": "^8.0.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "sass": "^1.99.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.4.2",
    "vitepress": "^1.6.4",
    "vitest": "^2.0.0",
    "wait-on": "^9.0.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KrommerGmbH/cmh-chatbot.git"
  },
  "license": "MIT",
  "keywords": [
    "ai",
    "chatbot",
    "llama-cpp",
    "gguf",
    "local-llm",
    "bullmq",
    "hono"
  ]
}
